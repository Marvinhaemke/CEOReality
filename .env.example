# Meta Conversions API (CAPI)
# Set these as Vercel project environment variables (Production + Preview).

# Meta Pixel ID (same value used by the browser pixel in index.html).
# Optional — falls back to the hardcoded ID in api/meta-capi.js if unset.
META_PIXEL_ID=26542472978694567

# CAPI access token from Events Manager → Settings → Conversions API.
# REQUIRED. Treat as a secret — never commit, never expose to the client.
META_CAPI_ACCESS_TOKEN=

# Optional: Test Event Code from Events Manager → Test Events.
# When set, all events go to the test stream instead of production.
# Leave empty in production deployments.
META_TEST_EVENT_CODE=
